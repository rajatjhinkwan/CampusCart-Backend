# Copy to .env for local development. On Render, set these in the dashboard (never commit real values).

# Server
NODE_ENV=production
PORT=5000

# Database (MongoDB Atlas or local)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Auth
JWT_SECRET=your-jwt-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-jwt-refresh-secret-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated allowed frontend origins (no trailing slashes)
# Render example:
# CORS_ORIGINS=https://campus-cart-frontend-kye8.vercel.app,http://localhost:5173,https://localhost:5173
CORS_ORIGINS=https://campus-cart-frontend-kye8.vercel.app,http://localhost:5173,https://localhost:5173

# Optional: primary frontend URL for email links (falls back to first CORS_ORIGINS entry)
FRONTEND_URL=https://campus-cart-frontend-kye8.vercel.app

# Google OAuth (backend verifies ID tokens)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Stripe (premium checkout — optional)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
PREMIUM_PRICE_CENTS=19900

# Email (SMTP — optional, for password reset / notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
FROM_EMAIL=support@yourdomain.com

# Geo / routing proxies (optional overrides)
NOMINATIM_CONTACT=contact@example.com
OSRM_BASE=https://router.project-osrm.org

# Data science microservice (optional)
DS_SERVICE_URL=http://localhost:8000/predict-price

# Logging
LOG_LEVEL=info
